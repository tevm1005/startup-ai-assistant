# Prefix all vars with SA_ (e.g. SA_DATABASE_URL)
SA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/startup_assistant
SA_LLM_API_KEY=sk-...
SA_LLM_MODEL=gpt-4o
SA_EMBEDDING_MODEL=text-embedding-3-small
SA_DEBUG=false

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
